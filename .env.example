# ── Local development ──────────────────────────────────────────
DATABASE_URL=postgres://postgres:YOUR_LOCAL_PG_PASSWORD@localhost:5432/egrm
JWT_SECRET=change-me-in-prod
PII_SECRET=change-me-pii-in-prod
API_PORT=4100
DEFAULT_TENANT=kisip
=
# Notifications
PUBLIC_PORTAL_BASE_URL=http://localhost:3000
# Log SMS/email to API stdout instead of calling providers (good for local dev)
NOTIFICATIONS_DEV_LOG_ONLY=1
ATTACHMENTS_STORAGE_PATH=./data/attachments
=
# ── Railway / production (API service) ───────────────────────────
# PORT is injected automatically by Railway
# DATABASE_PUBLIC_URL=${{Postgres.DATABASE_PUBLIC_URL}}  # for railway run db:* from your PC
# SEED_ON_DEPLOY=1     # force seed on every deploy (default: only when DB has no tenants)
# SEED_TENANT_HOSTNAMES=portal-xxx.up.railway.app,console-xxx.up.railway.app
=
# ── Railway / production (Portal & Console services) ───────────
