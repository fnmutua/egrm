# ── Local development ──────────────────────────────────────────
DATABASE_URL=postgres://postgres:YOUR_LOCAL_PG_PASSWORD@localhost:5432/egrm
JWT_SECRET=change-me-in-prod
PII_SECRET=change-me-pii-in-prod
API_PORT=4100
DEFAULT_TENANT=kisip
REDIS_URL=redis://localhost:6379

# Notifications (Phase 2)
PUBLIC_PORTAL_BASE_URL=http://localhost:3000
# Log SMS/email to API stdout instead of calling providers (good for local dev)
NOTIFICATIONS_DEV_LOG_ONLY=1
# Dispatch inline in API when Redis worker is not running (alternative to worker)
# NOTIFICATIONS_SYNC_DISPATCH=1

# Advanta SMS (KISIP plus-admin — fallback when CD-09 api_token is empty)
# SMS_API_KEY=
# SMS_PARTNER_ID=12108
# SMS_SHORTCODE=KISIP

# ── Railway / production (API service) ───────────────────────────
# DATABASE_URL=${{Postgres.DATABASE_URL}}   # reference in Railway dashboard
# PORT is injected automatically by Railway
# JWT_SECRET=<generate: openssl rand -hex 32>
# PII_SECRET=<generate: openssl rand -hex 32>
# DEFAULT_TENANT=kisip
# SEED_TENANT_HOSTNAMES=your-portal.up.railway.app,your-console.up.railway.app

# ── Railway / production (Portal & Console services) ───────────
# NUXT_PUBLIC_API_BASE=https://your-api.up.railway.app
# NUXT_PUBLIC_TENANT=kisip
