{
  "name": "@egrm/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./dispatch": {
      "types": "./dist/services/notification-dispatch.d.ts",
      "import": "./dist/services/notification-dispatch.js"
    },
    "./notification-queue": {
      "types": "./dist/services/notification-queue.d.ts",
      "import": "./dist/services/notification-queue.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/db/migrate.js && node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:setup": "tsx src/db/setup.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@egrm/config-schemas": "workspace:*",
    "@egrm/core": "workspace:*",
    "@egrm/notifications": "workspace:*",
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.44.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "pg": "^8.13.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
